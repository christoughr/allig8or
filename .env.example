# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Claude AI — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=https://allig8or.com

# Lemon Squeezy — https://app.lemonsqueezy.com/settings/api
#
# allig8or store not approved yet? Use **mnemonic** store temporarily:
#   NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID=mnemonic   (your mnemonic store slug)
# Create products named "allig8or Pro" / "allig8or Team" under mnemonic.
# When allig8or store is approved, swap slug + variant IDs only.
#
# Webhook: https://allig8or-lovat.vercel.app/api/webhooks/lemonsqueezy
LEMONSQUEEZY_API_KEY=your_api_key
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret
NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID=mnemonic
NEXT_PUBLIC_LEMONSQUEEZY_VARIANT_PRO=variant_uuid_for_pro_plan
NEXT_PUBLIC_LEMONSQUEEZY_VARIANT_TEAM=variant_uuid_for_team_plan
